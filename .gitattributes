# Files tracked in the repo but not published to the webroot.
# `git archive` (used by deploy.sh) omits anything marked export-ignore.
DEPLOY.md      export-ignore
deploy.sh      export-ignore
.gitignore     export-ignore
.gitattributes export-ignore

# Blog build tooling — the site serves the pre-generated HTML, not these.
blog/build_blog.py export-ignore
blog/articles.json export-ignore

# Infra reference (versioned nginx config) — must never be served from the webroot.
infra/ export-ignore
